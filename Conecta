      <div class="rubro-card"><div class="icon">A</div><span>Abogados y contadores</span></div>
      <div class="rubro-card"><div class="icon">R</div><span>Restaurantes y catering</span></div>
    </div>
  </div>
</section>

<section class="pricing" id="precio">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow-dark">Modelo de pago</span>
      <h2>Sin riesgo para ti</h2>
    </div>
    <div class="price-box">
      <span class="tag">Pago por resultado</span>
      <h3>Pagas solo por cada lead real entregado</h3>
      <ul>
        <li>Sin mensualidades fijas obligatorias</li>
