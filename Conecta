<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Conecta Leads | Clientes reales, no promesas</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#0E2A47;
    --navy-deep:#081A2E;
    --gold:#C9A24B;
    --green:#2E7D5B;
    --ink:#101418;
    --cream:#F7F5EF;
    --gray:#5C6470;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--cream);
    color:var(--ink);
    font-family:'Inter',sans-serif;
    line-height:1.55;
  }
  h1,h2,h3,.display{
    font-family:'Sora',sans-serif;
    font-weight:700;
    letter-spacing:-0.01em;
  }
  a{text-decoration:none;color:inherit;}
  img{max-width:100%;display:block;}
  .wrap{max-width:1140px;margin:0 auto;padding:0 24px;}

  /* NAV */
  nav{
    position:sticky;top:0;z-index:50;
    background:rgba(247,245,239,0.92);
    backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(14,42,71,0.1);
  }
  nav .wrap{display:flex;justify-content:space-between;align-items:center;padding:18px 24px;}
  .brand{font-family:'Sora',sans-serif;font-size:1.35rem;font-weight:800;color:var(--navy);}
  .brand span{color:var(--gold);}
  .nav-links{display:flex;gap:30px;font-size:0.9rem;font-weight:600;color:var(--navy);}
  .nav-cta{
    background:var(--green);color:#fff;
    padding:11px 22px;border-radius:6px;font-size:0.88rem;font-weight:700;
  }
  @media(max-width:760px){.nav-links{display:none;}}

  /* HERO */
  .hero{
    position:relative;
    background:linear-gradient(160deg, var(--navy) 0%, var(--navy-deep) 100%);
    color:#fff;
    overflow:hidden;
    padding:110px 0 100px;
  }
  .hero::before{
    content:'';
    position:absolute; top:-120px; right:-120px;
    width:420px;height:420px;border-radius:50%;
    background:radial-gradient(circle, rgba(201,162,75,0.25), transparent 70%);
  }
  .hero .wrap{position:relative;z-index:2;text-align:center;max-width:820px;}
  .eyebrow{
    display:inline-block;
    font-size:0.78rem;letter-spacing:0.14em;text-transform:uppercase;
    color:var(--gold);font-weight:700;margin-bottom:20px;
    border:1px solid rgba(201,162,75,0.4);padding:6px 16px;border-radius:20px;
  }
  .hero h1{font-size:clamp(2.4rem,5.5vw,3.8rem);line-height:1.08;margin-bottom:22px;}
  .hero h1 em{font-style:normal;color:var(--gold);}
  .hero p{font-size:1.1rem;color:rgba(255,255,255,0.75);max-width:560px;margin:0 auto 36px;}
  .btn-row{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
  .btn{
    display:inline-block;padding:15px 30px;font-weight:700;font-size:0.92rem;
    border-radius:6px;border:1px solid transparent;
  }
  .btn-primary{background:var(--green);color:#fff;}
  .btn-primary:hover{background:#256a4c;}
  .btn-ghost{border-color:rgba(255,255,255,0.35);color:#fff;}
  .btn-ghost:hover{border-color:var(--gold);color:var(--gold);}

  /* TRUST STRIP */
  .trust{background:var(--navy-deep);border-top:1px solid rgba(255,255,255,0.08);}
  .trust .wrap{display:flex;justify-content:space-between;padding:26px 24px;flex-wrap:wrap;gap:16px;}
  .trust-item{color:rgba(255,255,255,0.55);font-size:0.85rem;font-weight:600;text-align:center;flex:1;min-width:150px;}
  .trust-item b{display:block;color:var(--gold);font-family:'Sora',sans-serif;font-size:1.5rem;margin-bottom:4px;}

  /* HOW IT WORKS */
  .section{padding:96px 0;}
  .section-head{text-align:center;max-width:600px;margin:0 auto 56px;}
  .section-head .eyebrow-dark{color:var(--green);font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:12px;display:block;}
  .section-head h2{font-size:clamp(1.9rem,3.5vw,2.6rem);color:var(--navy);margin-bottom:14px;}
  .section-head p{color:var(--gray);font-size:1rem;}

  .steps{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;}
  @media(max-width:900px){.steps{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:560px){.steps{grid-template-columns:1fr;}}
  .step{
    background:#fff;border-radius:12px;padding:30px 24px;
    border:1px solid rgba(14,42,71,0.08);
    box-shadow:0 2px 10px rgba(14,42,71,0.04);
  }
  .step .num{
    width:38px;height:38px;border-radius:8px;
    background:var(--navy);color:var(--gold);
    display:flex;align-items:center;justify-content:center;
    font-family:'Sora',sans-serif;font-weight:800;font-size:1rem;margin-bottom:16px;
  }
  .step h3{font-size:1.05rem;color:var(--navy);margin-bottom:10px;}
  .step p{font-size:0.88rem;color:var(--gray);}

  /* WHY / RUBROS */
  .rubros{background:#fff;border-top:1px solid rgba(14,42,71,0.08);border-bottom:1px solid rgba(14,42,71,0.08);}
  .rubros .wrap{padding:96px 24px;}
  .rubro-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
  @media(max-width:820px){.rubro-grid{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:560px){.rubro-grid{grid-template-columns:1fr;}}
  .rubro-card{
    padding:22px;border-radius:10px;background:var(--cream);
    display:flex;align-items:center;gap:14px;
    border-left:4px solid var(--gold);
  }
  .rubro-card .icon{
    width:42px;height:42px;border-radius:50%;
    background:var(--navy);color:var(--gold);
    display:flex;align-items:center;justify-content:center;
    font-family:'Sora',sans-serif;font-weight:800;font-size:1.1rem;flex-shrink:0;
  }
  .rubro-card span{font-weight:600;color:var(--navy);font-size:0.95rem;}

  /* PRICING MODEL */
  .pricing{background:var(--cream);}
  .pricing .wrap{padding:96px 24px;}
  .price-box{
    max-width:640px;margin:0 auto;
    background:linear-gradient(160deg, var(--navy), var(--navy-deep));
    border-radius:16px;padding:44px 40px;color:#fff;text-align:center;
    box-shadow:0 12px 40px rgba(14,42,71,0.25);
  }
  .price-box .tag{color:var(--gold);font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:14px;display:block;}
  .price-box h3{font-size:1.7rem;margin-bottom:18px;}
  .price-box ul{list-style:none;text-align:left;max-width:400px;margin:0 auto 28px;}
  .price-box li{padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.1);font-size:0.94rem;color:rgba(255,255,255,0.85);display:flex;gap:10px;align-items:flex-start;}
  .price-box li::before{content:'✓';color:var(--green);font-weight:800;}

  /* TESTIMONIAL / QUOTE */
  .quote{text-align:center;padding:100px 24px;max-width:740px;margin:0 auto;}
  .quote p{font-family:'Sora',sans-serif;font-size:clamp(1.3rem,2.4vw,1.7rem);line-height:1.4;color:var(--navy);font-weight:600;}
  .quote .who{margin-top:22px;font-size:0.85rem;color:var(--gray);font-weight:600;}

  /* CONTACT */
  .contact{background:linear-gradient(160deg, var(--navy) 0%, var(--navy-deep) 100%);color:#fff;}
  .contact .wrap{padding:96px 24px;text-align:center;}
  .contact h2{font-size:clamp(2rem,4vw,2.8rem);margin-bottom:16px;}
  .contact p{color:rgba(255,255,255,0.7);max-width:480px;margin:0 auto 34px;}

  footer{background:var(--navy-deep);color:rgba(255,255,255,0.4);text-align:center;padding:26px 24px;font-size:0.8rem;}
</style>
</head>
<body>

<nav>
  <div class="wrap">
    <div class="brand">Conecta<span>Leads</span></div>
    <div class="nav-links">
      <a href="#como-funciona">Cómo funciona</a>
      <a href="#rubros">Rubros</a>
      <a href="#precio">Precio</a>
    </div>
    <a class="nav-cta" href="https://wa.me/18295592268" target="_blank">Quiero mis primeros leads</a>
  </div>
</nav>

<header class="hero">
  <div class="wrap">
    <div class="eyebrow">Generación de leads · República Dominicana</div>
